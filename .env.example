# =============================================================================
# Docker Compose ルート用 .env (リポジトリ全体)
# このファイルを .env としてコピーして利用する。git にはコミットしない。
# =============================================================================

# MySQL — DB_PASSWORD と DB_ROOT_PASSWORD は必ず初回セットアップで変更すること
DB_ROOT_PASSWORD=
DB_DATABASE=instaauto
DB_USERNAME=instaauto
DB_PASSWORD=

# Redis (パスワードなしのデフォルト構成。本番では必ず設定する)
REDIS_PASSWORD=

# ホスト側公開ポート (ローカルで他の MySQL/Redis と競合する場合に変更)
HOST_MYSQL_PORT=3308
HOST_REDIS_PORT=6380

# Frontend → Backend
NEXT_PUBLIC_API_URL=http://localhost:8080/api
