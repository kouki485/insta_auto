# =============================================================================
# Database (Laravel と同一の MySQL を共有)
# =============================================================================
DB_HOST=mysql
DB_PORT=3306
DB_USER=unara
DB_PASSWORD=secret
DB_NAME=unara

# =============================================================================
# Redis (Laravel ↔ Worker 連携)
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# Instagram (本番アカウント認証情報。git に絶対コミットしない)
# =============================================================================
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# =============================================================================
# Bright Data 住宅用プロキシ (sticky session 必須)
# =============================================================================
PROXY_URL=

# =============================================================================
# セッションファイル保存先 (DB の accounts.ig_session_path と整合させる)
# =============================================================================
SESSION_DIR=/storage/sessions

# =============================================================================
# Sentry / Slack
# =============================================================================
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# =============================================================================
# 動作パラメータ
# =============================================================================
LOG_LEVEL=INFO
WORKER_QUEUE_TIMEOUT=30
