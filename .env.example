# =============================================================================
# Docker Compose ルート用 .env (リポジトリ全体)
# このファイルを .env としてコピーして利用する。git にはコミットしない。
# =============================================================================

# -----------------------------------------------------------------------------
# ローカル動作確認モード
# -----------------------------------------------------------------------------
# true の場合 Worker は実 Instagram API を叩かずスタブで応答する.
# プロキシ・実 IG アカウント・セッションファイルなしで疎通確認できる.
# 本番運用時は false に切り替え, 各種シークレットを正しく設定すること.
LOCAL_MODE=true

# MySQL — ローカル確認用のダミー値. 本番では必ず変更すること.
DB_ROOT_PASSWORD=root
DB_DATABASE=instaauto
DB_USERNAME=instaauto
DB_PASSWORD=secret

# Redis (パスワードなしのデフォルト構成。本番では必ず設定する)
REDIS_PASSWORD=

# ホスト側公開ポート (ローカルで他のサービスと競合する場合に変更)
HOST_MYSQL_PORT=3308
HOST_REDIS_PORT=6380
HOST_API_PORT=8090

# Frontend → Backend
NEXT_PUBLIC_API_URL=http://localhost:8090/api

# -----------------------------------------------------------------------------
# Instagram / プロキシ (LOCAL_MODE=true なら全て空欄でよい)
# -----------------------------------------------------------------------------
INSTAGRAM_USERNAME=demo_account
INSTAGRAM_PASSWORD=stub-password
PROXY_URL=
