# =============================================================================
# Frontend (Next.js) 環境変数
# =============================================================================

# ブラウザ(CSR)から叩く Backend API URL (末尾の /api を含める)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Server Components / SSR からコンテナネットワーク経由で叩く URL
# Docker Compose では http://nginx/api、ローカル直起動なら NEXT_PUBLIC_API_URL と同じ値で可
INTERNAL_API_URL=http://localhost:8080/api

# Sanctum 認証用ドメイン
NEXT_PUBLIC_SANCTUM_DOMAIN=localhost:8080
