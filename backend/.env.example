APP_NAME=InstaAuto
# 本番では APP_ENV=production / APP_DEBUG=false に必ず変更すること.
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tokyo
# 本番例: https://api.example.com
APP_URL=http://localhost:8080

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Database (MySQL 8.0)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=instaauto
DB_USERNAME=instaauto
# ローカル動作確認用のダミー値. 本番では必ず強いパスワードへ変更すること.
DB_PASSWORD=secret

# =============================================================================
# Cache / Session / Queue
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=instaauto

# =============================================================================
# Redis (Laravel ↔ Python Worker 連携用)
# =============================================================================
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# Sanctum / CORS (Vercel フロントエンド用)
# =============================================================================
# 本番では Vercel ドメインに差し替える(例: SANCTUM_STATEFUL_DOMAINS=app.example.com)
SANCTUM_STATEFUL_DOMAINS=localhost:3000
# CORS の allowed_origins に追加される。本番は https://app.example.com など.
FRONTEND_URL=http://localhost:3000
SESSION_DOMAIN=null

# =============================================================================
# Python Worker 連携 (本番時に絶対パスへ更新)
# =============================================================================
WORKER_PYTHON_PATH=/srv/instaauto/worker/venv/bin/python
WORKER_SCRIPT_PATH=/srv/instaauto/worker/main.py
WORKER_SESSION_DIR=/storage/sessions

# =============================================================================
# Anthropic Claude API (DM 文面生成)
#
# ローカル動作確認では空のままで OK.
# DmGeneratorService は API キー未設定 / dailyLimit=0 のとき dm_templates の
# テンプレ展開へ自動フォールバックする (Anthropic 課金は発生しない).
# 本番運用時に正しいキー / モデル / 1日あたりの呼び出し上限を設定する.
# =============================================================================
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_API_DAILY_LIMIT=200

# =============================================================================
# Slack 通知 (緊急停止イベント)
# =============================================================================
SLACK_WEBHOOK_URL=

# =============================================================================
# Sentry
# =============================================================================
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Mail
# =============================================================================
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Seeder (db:seed が参照する初期管理ユーザー / 初期 IG アカウント)
# ローカル動作確認では下記のデフォルト値で OK.
# =============================================================================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password
SEED_ADMIN_NAME=ローカル管理者
SEED_IG_USERNAME=demo_account
SEED_IG_PASSWORD=stub-password
SEED_PROXY_URL=
SEED_SESSION_PATH=/storage/sessions/demo_account.json
SEED_STORE_NAME=Local Demo Store
